{
  "name": "erp-update-scheduler-api",
  "version": "1.0.0",
  "description": "API de Azure Functions para el programador de actualizaciones del ERP",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "npm run clean && tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run build",
    "start": "func start",
    "check:no-cosmos-runtime": "node scripts/check-no-cosmos-runtime.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "security:audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1094.0",
    "@aws-sdk/s3-request-presigner": "^3.1094.0",
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.2.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/storage-blob": "12.27.0",
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.1.3",
    "jsonwebtoken": "^9.0.2",
    "mssql": "12.7.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mssql": "12.3.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@azure/core-rest-pipeline": "1.23.0",
    "@azure/core-xml": "1.5.0",
    "axios": "1.18.1"
  }
}
