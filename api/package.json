{
  "name": "erp-update-scheduler-api",
  "version": "1.0.0",
  "description": "API de Azure Functions para el programador de actualizaciones del ERP",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "dist/src/index.js",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "prestart": "npm run build",
    "start": "func start",
    "export:cosmos": "node scripts/export-cosmos-snapshot.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "security:audit": "npm audit --audit-level=moderate",
    "security:sanitize-audit": "node scripts/sanitize-audit-logs.js"
  },
  "dependencies": {
    "@azure/cosmos": "^4.0.0",
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.2.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.9"
  }
}
